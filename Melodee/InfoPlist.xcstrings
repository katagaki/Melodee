    "NSPhotoLibraryAddUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melodee can save images to your Photos library."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melodeeは画像を「写真」ライブラリに保存できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melodee가 이미지를 사진 보관함에 저장할 수 있습니다."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melodee có thể lưu hình ảnh vào thư viện Ảnh của bạn."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melodee 可以将图像保存到您的“照片”图库。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Melodee 可以將圖像儲存到您的「照片」圖庫。"
          }
        }
      }
    }
  },
  "version" : "1.0"
